# ─────────────────────────────────────────────────────────
# AURA BOT — Variables d'environnement
# Copier en .env et remplir — NE JAMAIS committer .env !
# ─────────────────────────────────────────────────────────

# Discord Bot Token — https://discord.com/developers/applications
DISCORD_TOKEN=TON_BOT_TOKEN

# Client ID du bot (= Application ID)
CLIENT_ID=TON_CLIENT_ID

# ID du serveur Discord sur lequel déployer les commandes
GUILD_ID=TON_GUILD_ID

# UnbelievaBoat API Token — https://unbelievaboat.com/applications
# Authorization header = juste le token, sans préfixe "Bearer"
UNB_TOKEN=TON_TOKEN_UNB
